# Agnes API 配置
#
# 优先级：AGNES_API_KEY > NEXT_PUBLIC_AGNES_API_KEY > Settings 页面 (localStorage)
#
# AGNES_API_KEY（服务端环境变量，仅 Node.js 环境可用，优先级最高）
#   适用于 Docker / Vercel / CI/CD 等服务器部署
#
# NEXT_PUBLIC_AGNES_API_KEY（客户端环境变量，浏览器也可读取）
#   适用于 Next.js 开发环境，Next.js 编译时注入
#
# Settings 页面（localStorage）
#   适用于开发者在浏览器中手动输入，覆盖环境变量
#

# 服务端环境变量（推荐用于生产部署）
# AGNES_API_KEY=sk-your-key-here

# 客户端环境变量（推荐用于开发测试）
NEXT_PUBLIC_AGNES_API_KEY=

# Base URL（一般无需修改）
NEXT_PUBLIC_AGNES_BASE_URL=https://apihub.agnes-ai.com/v1

# 默认模型（一般无需修改）
NEXT_PUBLIC_AGNES_MODEL=agnes-image-2.1-flash
